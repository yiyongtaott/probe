{
  "env": {
    "ANTHROPIC_AUTH_TOKEN": "sk-bvZdphagAXdvFKy4tyJySVwVy3Ukf1ZyVXzKUJ9vkC2WA467",
    "ANTHROPIC_BASE_URL": "http://127.0.0.1:3000",
    "ANTHROPIC_MODEL": "deepseek-v4-flash-free[1m]",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "claude-opus-4-8[1m]",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "gemini-3.5-flash[1m]",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "gemini-3.1-flash-lite[1m]",
    "OTEL_LOG_RAW_API_BODIES": "file:/tmp/claude-api.log",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "CLAUDE_CODE_DEBUG_LOG_LEVEL": "debug",
    "API_TIMEOUT_MS": "3000000"
  },
  "permissions": {
    "defaultMode": "bypassPermissions"
  },
  "model": "deepseek-v4-flash-free[1m][1m]",
  "effortLevel": "xhigh",
  "skipDangerousModePermissionPrompt": true,
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -WindowStyle Hidden -File \"$USERPROFILE/.claude/notify.ps1\"",
            "timeout": 8,
            "async": true
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -WindowStyle Hidden -File \"$USERPROFILE/.claude/notify.ps1\"",
            "timeout": 8,
            "async": true
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "AskUserQuestion|EnterPlanMode|ExitPlanMode|EnterWorktree",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -WindowStyle Hidden -File \"$USERPROFILE/.claude/notify.ps1\"",
            "timeout": 8,
            "async": true
          }
        ]
      }
    ]
  }
}
